# App
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# Supabase
# When NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, the Discord
# ready-to-advance system persists to Supabase. Otherwise it falls back to an
# in-memory store (data resets on restart) for local development.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://localhost:5432/postgres
SUPABASE_STORAGE_BUCKET=dynasty-screenshots

# Discord
# Set DISCORD_BOT_ENABLED=true to start the bot on boot (via instrumentation.ts).
# When enabled, DISCORD_BOT_TOKEN is REQUIRED, and DISCORD_APPLICATION_ID +
# DISCORD_GUILD_ID are required to (re)register the guild-scoped slash commands.
DISCORD_BOT_ENABLED=false
# Required when DISCORD_BOT_ENABLED=true. Bot token from the Discord developer portal.
DISCORD_BOT_TOKEN=
# Required to register slash commands. The application (client) id.
DISCORD_APPLICATION_ID=
# Required to register slash commands. The guild (server) id commands are scoped to.
DISCORD_GUILD_ID=
# Optional: role id allowed to run /advance (falls back to Manage Server permission)
DISCORD_COMMISSIONER_ROLE_ID=
# Optional: link Discord users to seeded teams for the in-memory ready store (JSON array)
# e.g. [{"discordUserId":"123456789012345678","teamId":"team-thunder"}]
# When Supabase is configured, set teams.discord_user_id in the database instead.
DISCORD_TEAM_LINKS=

# League / ready-to-advance system
LEAGUE_DYNASTY_ID=default
LEAGUE_START_WEEK=1
# Number of ready teams required to advance, or "ALL" to require every team
LEAGUE_ADVANCE_THRESHOLD=ALL

# xAI / Grok
XAI_API_KEY=
XAI_API_BASE_URL=https://api.x.ai/v1/chat/completions
XAI_MODEL_TEXT=grok-3-latest
XAI_MODEL_VISION=grok-2-vision-latest

# Railway-friendly deploy variables
RAILWAY_ENVIRONMENT_NAME=
RAILWAY_PUBLIC_DOMAIN=
