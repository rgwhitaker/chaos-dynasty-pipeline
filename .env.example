# App
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# Supabase
# When NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, the Discord
# ready-to-advance system persists to Supabase. Otherwise it falls back to an
# in-memory store (data resets on restart) for local development.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://localhost:5432/postgres
SUPABASE_STORAGE_BUCKET=dynasty-screenshots

# Discord
# Set DISCORD_BOT_ENABLED=true to start the bot on boot (via instrumentation.ts).
# When enabled, DISCORD_BOT_TOKEN is REQUIRED, and DISCORD_APPLICATION_ID +
# DISCORD_GUILD_ID are required to (re)register the guild-scoped slash commands.
DISCORD_BOT_ENABLED=false
# Required when DISCORD_BOT_ENABLED=true. Bot token from the Discord developer portal.
DISCORD_BOT_TOKEN=
# Required to register slash commands. The application (client) id.
DISCORD_APPLICATION_ID=
# Required to register slash commands. The guild (server) id commands are scoped to.
DISCORD_GUILD_ID=
# Optional: role id allowed to run /advance (falls back to Manage Server permission)
DISCORD_COMMISSIONER_ROLE_ID=
# Optional: link Discord users to seeded teams for the in-memory ready store (JSON array)
# e.g. [{"discordUserId":"123456789012345678","teamId":"team-thunder"}]
# When Supabase is configured, set teams.discord_user_id in the database instead.
DISCORD_TEAM_LINKS=
# Channel id where the Weekly Newspaper is posted (via /newspaper).
# When unset, the newspaper is generated and stored but not posted to Discord.
NEWSPAPER_CHANNEL_ID=
# Optional: image/banner shown as the newspaper embed thumbnail (e.g. your dynasty logo).
NEWSPAPER_IMAGE_URL=
# Channel id for the persistent status dashboard.
# When set, the bot maintains ONE live status message here (edited in place).
# When unset, the dashboard is not maintained.
STATUS_CHANNEL_ID=
# Channel id for the recurring "not ready" reminders (every 12 hours, pinging the
# teams still not ready for the current week). When unset, reminders fall back to
# STATUS_CHANNEL_ID; when neither is set, reminders are skipped.
REMINDER_CHANNEL_ID=

# League / ready-to-advance system
LEAGUE_DYNASTY_ID=default
LEAGUE_START_WEEK=1
# Number of ready teams required to advance, or "ALL" to require every team
LEAGUE_ADVANCE_THRESHOLD=ALL

# xAI / Grok
XAI_API_KEY=
XAI_API_BASE_URL=https://api.x.ai/v1/chat/completions
XAI_MODEL_TEXT=grok-3-latest
XAI_MODEL_VISION=grok-2-vision-latest

# Video processing (/process-video)
# ffmpeg/ffprobe are bundled via ffmpeg-static/ffprobe-static, so these are only
# needed to point at a system build instead (e.g. on a host that ships its own).
FFMPEG_PATH=
FFPROBE_PATH=

# OneDrive screenshot monitoring (background)
# When ONEDRIVE_CLIENT_ID/SECRET/TENANT_ID + ONEDRIVE_MONITORED_PATH are all set,
# the bot polls OneDrive (Microsoft Graph Delta API) for new Xbox screenshots,
# extracts structured data with Grok Vision, and stores it in the extracted_data
# table. Azure AD app (client credentials / app-only) values:
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
# Root OneDrive folder to monitor, relative to the drive root (e.g. "Xbox Screenshots").
# The bot infers the week + data type from subfolders like "2026 Week 2/Box Scores".
ONEDRIVE_MONITORED_PATH=
# Optional: folder to move processed files into (relative to the drive root).
# When unset, processed files are left in place.
ONEDRIVE_PROCESSED_PATH=
# Optional: explicit drive id to target. Required for app-only access to a
# specific user's OneDrive; when unset the client uses /me/drive.
ONEDRIVE_DRIVE_ID=
# Optional: how often (minutes) the background monitor polls. Default 3, min 1.
ONEDRIVE_POLL_INTERVAL_MINUTES=3
# Optional: set to "false" to keep credentials but disable the background poller
# (manual /sync-onedrive and /import-from-onedrive still work).
ONEDRIVE_MONITOR_ENABLED=true
# Optional: channel id for a short "imported N screenshots" summary after each
# processing run. Falls back to STATUS_CHANNEL_ID; when neither is set, silent.
ONEDRIVE_NOTIFY_CHANNEL_ID=

# Railway-friendly deploy variables
RAILWAY_ENVIRONMENT_NAME=
RAILWAY_PUBLIC_DOMAIN=
